enum ReadError {
    denied
}

enum SaveError {
    denied
}

func read() Result<int, ReadError> {
    return Result<int, ReadError>.failure(ReadError.denied())
}

func main() {
    var callback:func() Result<int, SaveError> = func() Result<int, SaveError> {
        let value = try read()
        return Result<int, SaveError>.success(value)
    }
}
