use ExtensionConformanceChecks.Core as Core
use ExtensionConformanceChecks.Types as Types

extend Types.Sprite : Core.Drawable, Core.Named {
    pub func draw() int {
        return self.value
    }

    pub func name() str {
        return "sprite"
    }
}

extend Types.Token : Core.Drawable {
    func draw() int {
        return self.value
    }
}
