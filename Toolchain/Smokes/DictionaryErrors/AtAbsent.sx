use STD.Collections.Dictionary as Dictionary
use STD.Collections.hash_int as hash_int
use STD.Collections.equal_int as equal_int

func consume(value:@int) {
    print(value == 1)
}

func main() {
    var values = Dictionary<int, int>.create(hash_int, equal_int)
    let missing:@int = values.at(1)
    consume(missing)
}
