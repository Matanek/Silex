native func native_open(label:int) int
native func native_close(handle:int) void

public enum OpenError {
    unavailable(int)
}

public protocol Readable {
    func value() int
}

public struct Resource : Readable {
    let handle:int
    let label:int

    static func open(label:int) Resource {
        return Resource(handle:native_open(label), label:label)
    }

    func value() int {
        return self.label
    }

    drop {
        native_close(self.handle)
    }
}

public func open_result(label:int, available:bool) Result<Resource,OpenError> {
    if available {
        return Result<Resource,OpenError>.success(Resource(handle:native_open(label), label:label))
    }
    return Result<Resource,OpenError>.failure(OpenError.unavailable(label))
}

public func maybe_open(label:int, complete:bool) Result<int,str> {
    if complete {
        return Result<int,str>.success(native_open(label))
    }
    print("reject")
    print(label)
    return Result<int,str>.failure("incomplete")
}

public func incomplete_initialization(label:int, complete:bool) Result<void,str> {
    let resource = Resource(handle:try maybe_open(label, complete), label:label)
    print("complete")
    print(resource.value())
    return Result<void,str>.success()
}
