use STD.Iteration.Iterator as Iterator

public struct Stack<T> {
    private var storage:T[]
    private var reserved_capacity:int

    public init() {
        self.storage = []
        self.reserved_capacity = 0
    }

    public init(minimum_capacity:int) {
        if minimum_capacity < 0 {
            panic("Stack requires a non-negative minimum capacity")
        }
        self.storage = []
        self.reserved_capacity = minimum_capacity
    }

    public func count() int {
        return self.storage.count()
    }

    public func capacity() int {
        let count = self.count()
        if self.reserved_capacity < count {
            return count
        }
        return self.reserved_capacity
    }

    public func is_empty() bool {
        return self.storage.is_empty()
    }

    public func push(value:T) {
        self.storage.append(value)
        let count = self.count()
        if count > self.reserved_capacity {
            var capacity = self.reserved_capacity
            if capacity < 4 {
                capacity = 4
            }
            while capacity < count {
                capacity *= 2
            }
            self.reserved_capacity = capacity
        }
    }

    public func pop() T? {
        if self.storage.is_empty() {
            return null
        }
        return self.storage.take_last()
    }

    public func peek() & T {
        if self.storage.is_empty() {
            panic("Stack.peek requires a value")
        }
        return &self.storage[-1]
    }

    public func reserve(minimum_capacity:int) {
        if minimum_capacity < 0 {
            panic("Stack.reserve requires a non-negative minimum capacity")
        }
        if minimum_capacity > self.reserved_capacity {
            self.reserved_capacity = minimum_capacity
        }
    }

    public func clear() {
        while !self.storage.is_empty() {
            self.storage.take_last()
        }
    }

    public func iterator() Iterator<T> {
        var result = Iterator<T>.empty()
        var index = self.storage.count() - 1
        while index >= 0 {
            result.push(self.storage[index])
            index--
        }
        return result
    }
}
