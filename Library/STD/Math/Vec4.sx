use STD.Math
use STD.Math.Vec3 as Vec3

public struct Vec4 {
    var x:float
    var y:float
    var z:float
    var w:float

    init() {}

    init(value:float) {
        self.x = value
        self.y = value
        self.z = value
        self.w = value
    }

    init(x:float, y:float, z:float, w:float) {
        self.x = x
        self.y = y
        self.z = z
        self.w = w
    }

    init(xyz:Vec3, w:float) {
        self.x = xyz.x
        self.y = xyz.y
        self.z = xyz.z
        self.w = w
    }

    func xyz() Vec3 {
        return Vec3(self.x, self.y, self.z)
    }

    func add(other:Vec4) Vec4 {
        return Vec4(self.x + other.x, self.y + other.y, self.z + other.z, self.w + other.w)
    }

    func subtract(other:Vec4) Vec4 {
        return Vec4(self.x - other.x, self.y - other.y, self.z - other.z, self.w - other.w)
    }

    func multiply(other:Vec4) Vec4 {
        return Vec4(self.x * other.x, self.y * other.y, self.z * other.z, self.w * other.w)
    }

    func multiply(scalar:float) Vec4 {
        return Vec4(self.x * scalar, self.y * scalar, self.z * scalar, self.w * scalar)
    }

    func divide(other:Vec4) Vec4 {
        return Vec4(self.x / other.x, self.y / other.y, self.z / other.z, self.w / other.w)
    }

    func divide(scalar:float) Vec4 {
        return Vec4(self.x / scalar, self.y / scalar, self.z / scalar, self.w / scalar)
    }

    func negated() Vec4 {
        return Vec4(-self.x, -self.y, -self.z, -self.w)
    }

    func dot(other:Vec4) float {
        return self.x * other.x + self.y * other.y + self.z * other.z + self.w * other.w
    }

    func length_squared() float {
        return self.dot(self)
    }

    func length() float {
        return Math.sqrt(self.length_squared())
    }

    func distance(other:Vec4) float {
        return self.subtract(other).length()
    }

    func normalized() Vec4 {
        let length = self.length()
        if length <= Math.epsilon() {
            return Vec4.zero()
        }
        return self.divide(length)
    }

    func lerp(other:Vec4, amount:float) Vec4 {
        return Vec4(
            Math.lerp(self.x, other.x, amount),
            Math.lerp(self.y, other.y, amount),
            Math.lerp(self.z, other.z, amount),
            Math.lerp(self.w, other.w, amount)
        )
    }

    func mix(other:Vec4, amount:float) Vec4 {
        return self.lerp(other, amount)
    }

    func minimum(other:Vec4) Vec4 {
        return Vec4(
            Math.min(self.x, other.x),
            Math.min(self.y, other.y),
            Math.min(self.z, other.z),
            Math.min(self.w, other.w)
        )
    }

    func maximum(other:Vec4) Vec4 {
        return Vec4(
            Math.max(self.x, other.x),
            Math.max(self.y, other.y),
            Math.max(self.z, other.z),
            Math.max(self.w, other.w)
        )
    }

    func clamped(minimum:Vec4, maximum:Vec4) Vec4 {
        return Vec4(
            Math.clamp(self.x, minimum.x, maximum.x),
            Math.clamp(self.y, minimum.y, maximum.y),
            Math.clamp(self.z, minimum.z, maximum.z),
            Math.clamp(self.w, minimum.w, maximum.w)
        )
    }

    func nearly_equal(other:Vec4) bool {
        return self.nearly_equal(other, Math.epsilon())
    }

    func nearly_equal(other:Vec4, tolerance:float) bool {
        return Math.nearly_equal(
            self.x,
            other.x,
            tolerance
        ) && Math.nearly_equal(
            self.y,
            other.y,
            tolerance
        ) && Math.nearly_equal(
            self.z,
            other.z,
            tolerance
        ) && Math.nearly_equal(self.w, other.w, tolerance)
    }
}

extend Vec4 {
    static func zero() Vec4 {
        return Vec4()
    }

    static func one() Vec4 {
        return Vec4(1.0)
    }

    static func unit_x() Vec4 {
        return Vec4(1.0, 0.0, 0.0, 0.0)
    }

    static func unit_y() Vec4 {
        return Vec4(0.0, 1.0, 0.0, 0.0)
    }

    static func unit_z() Vec4 {
        return Vec4(0.0, 0.0, 1.0, 0.0)
    }

    static func unit_w() Vec4 {
        return Vec4(0.0, 0.0, 0.0, 1.0)
    }
}
