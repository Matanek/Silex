{
  "Main function": {
    "prefix": "main",
    "body": [
      "func main() void {",
      "    $0",
      "}"
    ],
    "description": "Silex program entry point"
  },
  "Print": {
    "prefix": "print",
    "body": [
      "print(\"${1:text}\")",
      "$0"
    ],
    "description": "Print a line"
  },
  "Immutable variable": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}",
      "$0"
    ],
    "description": "Declare an immutable inferred variable"
  },
  "Mutable variable": {
    "prefix": "var",
    "body": [
      "var ${1:name} = ${2:value}",
      "$0"
    ],
    "description": "Declare a mutable inferred variable"
  },
  "Default initialized variable": {
    "prefix": "vart",
    "body": [
      "var ${1:name}:${2:type}",
      "$0"
    ],
    "description": "Declare a typed variable with its default value"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "    $0",
      "}"
    ],
    "description": "Conditional block"
  },
  "If else statement": {
    "prefix": "ife",
    "body": [
      "if (${1:condition}) {",
      "    ${2}",
      "} else {",
      "    $0",
      "}"
    ],
    "description": "Conditional block with alternative"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "    $0",
      "}"
    ],
    "description": "Loop while a condition is true"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2}) ${3:void} {",
      "    $0",
      "}"
    ],
    "description": "Declare a function"
  },
  "Method": {
    "prefix": "method",
    "body": [
      "func ${1:name}(${2}) ${3:void} {",
      "    $0",
      "}"
    ],
    "description": "Declare a struct method"
  },
  "Return": {
    "prefix": "return",
    "body": [
      "return ${1:value}"
    ],
    "description": "Return from a function"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}:${3:int}",
      "}",
      "$0"
    ],
    "description": "Declare a value type"
  },
  "Default struct field": {
    "prefix": "field",
    "body": [
      "${1:name}:${2:type} = ${3:value}"
    ],
    "description": "Declare a struct field with an explicit default"
  }
}
